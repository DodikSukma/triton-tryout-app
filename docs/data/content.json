  "env_vars": [
    { "key": "POSTGRES_HOST", "default": "localhost", "services": "semua service", "description": "Host PostgreSQL" },
    { "key": "POSTGRES_PORT", "default": "5432", "services": "semua service", "description": "Port PostgreSQL" },
    { "key": "POSTGRES_USER", "default": "triton_user", "services": "semua service", "description": "Username PostgreSQL" },
    { "key": "POSTGRES_PASSWORD", "default": "triton_secret_2024", "services": "semua service", "description": "Password PostgreSQL" },
    { "key": "POSTGRES_DB", "default": "db_auth/db_user/db_soal/db_jawaban", "services": "per service", "description": "Nama database masing-masing service" },
    { "key": "SESSION_SECRET", "default": "triton-secret-key-2024", "services": "auth-service", "description": "Secret untuk signing session cookie" },
    { "key": "PORT", "default": "4001/4002/4003/4004", "services": "per service", "description": "Port listening service" },
    { "key": "AUTH_SERVICE_URL", "default": "http://localhost:4001", "services": "gateway, user-service, jawaban-service", "description": "URL auth-service" },
    { "key": "USER_SERVICE_URL", "default": "http://localhost:4002", "services": "gateway, jawaban-service", "description": "URL user-service" },
    { "key": "SOAL_SERVICE_URL", "default": "http://localhost:4003", "services": "gateway, jawaban-service", "description": "URL soal-service" },
    { "key": "JAWABAN_SERVICE_URL", "default": "http://localhost:4004", "services": "gateway", "description": "URL jawaban-service" },
    { "key": "FRONTEND_URL", "default": "http://localhost:3000", "services": "gateway (CORS)", "description": "URL frontend untuk CORS whitelist" }
  ],
  "faq": [
    { "q": "bagaimana cara menambah siswa", "a": "Login sebagai Admin → Kelola Siswa (/admin/users?role=siswa) → Tambah Siswa → isi email, password, nama, kelas → POST /users." },
    { "q": "bagaimana guru membuat soal", "a": "Login sebagai Guru → Dashboard → Buat Tryout → redirect ke /guru/tryout/{id}/soal → Tambah Soal (manual atau AI generate) → isi pertanyaan, pilihan, tandai jawaban benar → Publish." },
    { "q": "bagaimana siswa memulai tryout", "a": "Login sebagai Siswa → Tryout Tersedia → pilih tryout → Mulai Tryout → baca aturan → Mulai → kerjakan soal → Kumpulkan." },
    { "q": "bagaimana nilai dihitung", "a": "Nilai = (total bobot soal benar / total bobot semua soal) × 100. Soal essay tidak dihitung otomatis (panduan tersedia untuk guru). Dihitung saat POST /sesi/:sesiId/selesai." },
    { "q": "apa itu session based auth", "a": "Auth menggunakan cookie session (triton.sid), bukan JWT. Session disimpan di database PostgreSQL (connect-pg-simple) atau Redis. Gateway memvalidasi setiap request ke /auth/me dan inject x-user-id + x-user-role ke header." },
    { "q": "berapa port masing masing service", "a": "Frontend: 3000, Gateway: 4000, Auth-service: 4001, User-service: 4002, Soal-service: 4003, Jawaban-service: 4004." },
    { "q": "api endpoint yang tersedia", "a": "Auth: POST /auth/login, POST /auth/logout, GET /auth/me, POST /auth/change-password. User: GET/POST /users, PATCH /users/:id/active, GET/PUT /users/profile/me, POST /users/profile/avatar. Soal: GET/POST /tryouts, GET /tryouts/available, GET/PUT/PATCH/DELETE /tryouts/:id, POST /tryouts/:id/soal, PUT/DELETE /soal/:soalId. Jawaban: POST/GET /sesi, POST /sesi/:sesiId/jawab, POST /sesi/:sesiId/selesai, GET /hasil/*, GET /riwayat." },
    { "q": "tabel apa saja di database", "a": "db_auth: users. db_user: profiles. db_soal: tryouts, soal, opsi_jawaban. db_jawaban: sesi_tryout, jawaban, hasil. Total 7 tabel di 4 database terpisah." },
    { "q": "bagaimana cara setup project", "a": "1. docker compose up -d postgres redis. 2. Buat 4 database (db_auth, db_user, db_soal, db_jawaban). 3. Jalankan schema migration tiap service. 4. cd scripts && npm run seed. 5. make dev (atau ts-node-dev per service). 6. cd frontend && npm run dev." },
    { "q": "akun default setelah seeding", "a": "admin@triton.id / admin123, guru1@triton.id / guru123, guru2@triton.id / guru123, siswa1@triton.id / siswa123, siswa2@triton.id / siswa123." }
  ]
}
